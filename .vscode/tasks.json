{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "激活 Python .venv 虚拟环境",
      "type": "shell",
      "command": "source .venv/Scripts/activate  && exec bash",
      "args": [],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "clear": true,
        "panel": "shared",
        "showReuseMessage": false
      }
    },
    {
      "label": "打包",
      "type": "shell",
      "command": "source .venv/Scripts/activate && pyinstaller --onefile --windowed --name \"Rukk Filter\" --add-data \"vue-web;vue-web\" --add-data \"config.json;.\" --add-data \"logo.png;.\" -i \"logo.png\" main.py  && exec bash",
      "args": [],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "clear": true,
        "panel": "shared",
        "showReuseMessage": false
      }
    }
  ]
}